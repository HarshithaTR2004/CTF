REACT_APP_API_URL=/api

# Dev only: fixes "allowedHosts[0] should be a non-empty string" when react-dev-utils
# cannot set a LAN host (e.g. non-private IP). Safe for local dev with react-scripts.
DANGEROUSLY_DISABLE_HOST_CHECK=true
# If frontend runs on port 5000, run backend on 5001 and set so the VM terminal is proxied correctly:
# REACT_APP_PROXY_TARGET=http://localhost:5001
